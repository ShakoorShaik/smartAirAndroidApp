<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:paddingStart="32dp"
    android:paddingEnd="32dp"
    android:paddingTop="48dp"
    android:paddingBottom="32dp">

    <View
        android:id="@+id/viewColorAccent"
        android:layout_width="80dp"
        android:layout_height="4dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="#4CAF50" />

    <ImageView
        android:id="@+id/imageOnboardingIcon"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_marginTop="64dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_welcome"
        android:contentDescription="Onboarding icon"
        app:layout_constraintTop_toBottomOf="@id/viewColorAccent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/textOnboardingTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="56dp"
        android:text="Welcome to SmartAir"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:gravity="center"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.02"
        app:layout_constraintTop_toBottomOf="@id/imageOnboardingIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Welcome to SmartAir" />

    <TextView
        android:id="@+id/textOnboardingDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Your comprehensive asthma management companion."
        android:textSize="17sp"
        android:textColor="#616161"
        android:gravity="center"
        android:lineSpacingExtra="6dp"
        android:fontFamily="sans-serif"
        android:letterSpacing="0.01"
        app:layout_constraintTop_toBottomOf="@id/textOnboardingTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Your comprehensive asthma management companion. Monitor your child's respiratory health, track medications, and stay informed about their condition." />

</androidx.constraintlayout.widget.ConstraintLayout>

