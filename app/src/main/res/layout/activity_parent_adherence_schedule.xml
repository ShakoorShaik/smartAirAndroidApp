<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Configure Adherence Schedule"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Set up medication reminders for your child"
            android:textSize="14sp"
            android:textColor="@color/gray"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <!-- Frequency Question -->
        <TextView
            android:id="@+id/tvFrequencyQuestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="How many times a day?"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="16dp" />

        <!-- Radio Group for Frequency -->
        <RadioGroup
            android:id="@+id/rgFrequency"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <RadioButton
                android:id="@+id/rbOnceDaily"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Once Daily"
                android:textSize="18sp"
                android:padding="12dp"
                android:checked="true" />

            <RadioButton
                android:id="@+id/rbTwiceDaily"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Twice Daily"
                android:textSize="18sp"
                android:padding="12dp" />

        </RadioGroup>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/gray"
            android:layout_marginBottom="24dp" />

        <!-- Times Section Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Set Reminder Times"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="16dp" />

        <!-- Container for Times -->
        <LinearLayout
            android:id="@+id/llTimesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="32dp">

            <!-- Morning Time Button -->
            <TextView
                android:id="@+id/tvMorningTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Set Morning Time"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:background="@color/teal_700"
                android:padding="16dp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="12dp"
                android:drawableStart="@android:drawable/ic_menu_recent_history"
                android:drawablePadding="8dp" />

            <!-- Evening Time Button (Initially visible) -->
            <TextView
                android:id="@+id/tvEveningTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Set Evening Time"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:background="@color/teal_700"
                android:padding="16dp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone"
                android:drawableStart="@android:drawable/ic_menu_recent_history"
                android:drawablePadding="8dp" />

        </LinearLayout>

        <!-- Spacer to push button to bottom when needed -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Save Button -->
        <Button
            android:id="@+id/btnSaveSchedule"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Schedule"
            android:textSize="18sp"
            android:textStyle="bold"
            android:padding="16dp"
            android:backgroundTint="@color/green"
            android:textColor="@color/white" />

    </LinearLayout>

</ScrollView>
