<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#6100EC">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:gravity="center"
                    android:text="Adherence Schedule"
                    android:textColor="@color/white"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Set up medication reminders for your child"
                    android:textSize="14sp"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:alpha="0.9" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Child Selection Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Select Child"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_marginBottom="12dp" />

                <Spinner
                    android:id="@+id/spinnerChild"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@android:drawable/btn_dropdown"
                    android:padding="12dp"
                    android:spinnerMode="dropdown" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Frequency Selection Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="How often should medication be taken?"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_marginBottom="12dp" />

                <Spinner
                    android:id="@+id/spinnerFrequency"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@android:drawable/btn_dropdown"
                    android:padding="12dp"
                    android:spinnerMode="dropdown"
                    android:entries="@array/frequency_options" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Dose Times Section Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⏰ Set Dose Times"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="12dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp" />

        <!-- Dynamic Container for Dose Time Cards -->
        <LinearLayout
            android:id="@+id/llDoseTimesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="20dp">

            <!-- Dose 1 Card (Always visible) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardDose1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Dose 1"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#6100EC"
                        android:layout_marginBottom="12dp" />

                    <!-- Time Picker Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Time:"
                            android:textSize="16sp"
                            android:textColor="@color/black" />

                        <Button
                            android:id="@+id/btnDose1Time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Set Time"
                            android:textSize="14sp"
                            android:backgroundTint="#9C4DCC"
                            android:textColor="@color/white"
                            android:drawableStart="@android:drawable/ic_menu_recent_history"
                            android:drawablePadding="8dp"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Dose 2 Card (Initially hidden, shown when Twice Daily is selected) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardDose2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Dose 2"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#6100EC"
                        android:layout_marginBottom="12dp" />

                    <!-- Time Picker Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Time:"
                            android:textSize="16sp"
                            android:textColor="@color/black" />

                        <Button
                            android:id="@+id/btnDose2Time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Set Time"
                            android:textSize="14sp"
                            android:backgroundTint="#9C4DCC"
                            android:textColor="@color/white"
                            android:drawableStart="@android:drawable/ic_menu_recent_history"
                            android:drawablePadding="8dp"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- Save Button -->
        <Button
            android:id="@+id/btnSaveSchedule"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Save Schedule"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#6100EC"
            android:textColor="@color/white"
            android:elevation="4dp"
            android:layout_marginBottom="12dp" />

        <!-- Back Button -->
        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="← Back"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="@color/gray"
            android:textColor="@color/white"
            android:elevation="4dp" />

    </LinearLayout>

</ScrollView>
