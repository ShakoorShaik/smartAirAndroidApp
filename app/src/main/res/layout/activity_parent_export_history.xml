<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Export History"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select child"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinnerChildSelector"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:spinnerMode="dropdown"
            android:contentDescription="Select child" />

        <View
            android:layout_width="match_parent"
            android:layout_height="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select format"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/radioGroupFormat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/radioCsv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CSV"
                android:checked="true" />

            <RadioButton
                android:id="@+id/radioPdf"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PDF"
                android:layout_marginStart="24dp" />
        </RadioGroup>

        <View
            android:layout_width="match_parent"
            android:layout_height="24dp" />

        <!-- Filters Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Filters (optional)"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Date range -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/buttonStartDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Start date" />

            <View
                android:layout_width="12dp"
                android:layout_height="0dp" />

            <Button
                android:id="@+id/buttonEndDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="End date" />
        </LinearLayout>

        <TextView
            android:id="@+id/textSelectedDateRange"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No date range selected"
            android:textSize="12sp"
            android:textColor="@android:color/darker_gray"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp" />

        <!-- Symptoms filter -->
        <Button
            android:id="@+id/buttonSelectSymptoms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select symptoms" />

        <TextView
            android:id="@+id/textSelectedSymptoms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="All symptoms"
            android:textSize="12sp"
            android:textColor="@android:color/darker_gray"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp" />

        <!-- Triggers filter -->
        <Button
            android:id="@+id/buttonSelectTriggers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select triggers" />

        <TextView
            android:id="@+id/textSelectedTriggers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="All triggers"
            android:textSize="12sp"
            android:textColor="@android:color/darker_gray"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:id="@+id/buttonClearFilters"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Clear filters" />

            <View
                android:layout_width="12dp"
                android:layout_height="0dp" />

            <Button
                android:id="@+id/buttonApplyFilters"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Apply filters" />
        </LinearLayout>

        <TextView
            android:id="@+id/textViewExportInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ℹ️ Exported files will be saved to your Downloads folder"
            android:textSize="14sp"
            android:textColor="@android:color/darker_gray"
            android:padding="12dp"
            android:background="@android:color/transparent"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/buttonExport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Export" />

        <Button
            android:id="@+id/buttonOpenDownloads"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Open Downloads Folder"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/buttonReturn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Return"
            android:layout_marginTop="12dp" />

    </LinearLayout>
</ScrollView>
