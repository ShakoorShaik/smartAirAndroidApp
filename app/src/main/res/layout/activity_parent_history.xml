<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        tools:context=".child.ChildHistory.ChildHistoryPEFActivity"
        app:layout_constraintTop_toTopOf="parent"
        android:background="#F5F5F5"
        android:elevation=".1dp">
        <Button
            android:id="@+id/returnButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginLeft="20dp"
            android:layout_marginBottom="20dp"
            android:text="Return"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <View
            android:id="@+id/view"
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_marginVertical="10dp"
            android:background="#A0A0A0"
            app:layout_constraintStart_toEndOf="@id/returnButton"
            app:layout_constraintEnd_toStartOf="@id/childText"
            tools:layout_editor_absoluteX="20dp" />

        <TextView
            android:id="@+id/childText"
            android:layout_width="200dp"
            android:layout_height="30dp"
            android:layout_marginTop="10dp"
            android:text="  Displaying data for"
            android:textSize="16sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/view"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Spinner
            android:id="@+id/childSelector"
            android:layout_width="200dp"
            android:layout_height="50dp"
            android:layout_marginTop="30dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/view"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:id="@+id/content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
            android:id="@+id/scrollMain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="10dp"
            app:layout_constraintTop_toTopOf="parent"
            tools:context=".child.ChildHistory.ChildHistoryPEFActivity">

            <TextView
                android:id="@+id/historyText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="24sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginTop="30dp"
                android:text="History"/>

            <TextView
                android:id="@+id/symptomText"
                android:layout_width="0dp"
                android:layout_height="20dp"
                android:text="@string/symptoms"
                android:textAlignment="center"
                android:layout_marginTop="30dp"
                app:layout_constraintTop_toBottomOf="@id/historyText"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/triggerText"
                app:layout_constraintHorizontal_weight="1"/>

            <TextView
                android:id="@+id/triggerText"
                android:layout_width="0dp"
                android:layout_height="20dp"
                android:text="@string/triggers"
                android:textAlignment="center"
                android:layout_marginTop="30dp"
                app:layout_constraintTop_toBottomOf="@id/historyText"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/symptomText"
                app:layout_constraintHorizontal_weight="1"/>

            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/symptomGraph"
                android:layout_width="0dp"
                android:layout_height="200dp"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/symptomText"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/triggerGraph"
                app:layout_constraintHorizontal_weight="1"/>

            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/triggerGraph"
                android:layout_width="0dp"
                android:layout_height="200dp"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/triggerText"
                app:layout_constraintStart_toEndOf="@id/symptomGraph"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_weight="1"/>

            <TextView
                android:id="@+id/zoneText"
                android:layout_width="0dp"
                android:layout_height="20dp"
                android:text="@string/zone_history"
                android:textAlignment="center"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/symptomGraph"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/zoneGraph"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/zoneText"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginHorizontal="20dp"/>

            <TextView
                android:id="@+id/frequencyText"
                android:layout_width="0dp"
                android:layout_height="20dp"
                android:text="@string/rescue_control_usage"
                android:textAlignment="center"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/zoneGraph"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/frequencyGraph"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/frequencyText"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginHorizontal="20dp"/>

            <TextView
                android:id="@+id/emergencyText"
                android:layout_width="0dp"
                android:layout_height="20dp"
                android:text="@string/emergency_history"
                android:textAlignment="center"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/frequencyGraph"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/emergencyHistory"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:layout_constraintHeight="100dp"
                android:text="Loading Data..."
                android:textAlignment="center"
                app:layout_constraintTop_toBottomOf="@id/emergencyText"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>