<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/textInitialAmount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Initial Amount: 100%"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Amount Left (%):"
        android:textSize="16sp"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/editAmountLeft"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Enter amount left (0-100)"
        android:inputType="number"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Note: Update the amount left based on how much medication remains."
        android:textSize="12sp"
        android:textColor="#666666" />

</LinearLayout>

