<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center_horizontal">

    <TextView
        android:id="@+id/settingsText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Settings"
        android:textAlignment="center"
        android:textSize="24sp"
        android:layout_marginTop="30dp" />

    <Button
        android:id="@+id/buttonLogout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/logout"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/ChildPrivacy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="Configure Child-Provider Visibility" />

    <Button
        android:id="@+id/buttonThresholds"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Configure Child Badge Thresholds" />

    <Button
        android:id="@+id/buttonRescue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Configure Child Rescue Attempt Threshold" />

    <Button
        android:id="@+id/buttonExportHistory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Export PDF/CSV of history" />

    <Button
        android:id="@+id/buttonAdherenceSchedule"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Configure Adherence Schedule" />

</LinearLayout>

