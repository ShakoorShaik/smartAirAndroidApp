    </item>
    <item android:bottom="8dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/main_blue" />
            <corners android:radius="6dp"/>
            <size android:width="100dp" android:height="100dp" />
        </shape>
    </item>
</layer-list>
