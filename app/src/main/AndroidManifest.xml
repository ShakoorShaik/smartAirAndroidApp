<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SmartAir">
        <!-- Main Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />
        <!-- Launcher Activity -->
        <activity
            android:name=".Login"
            android:exported="true"
            android:theme="@style/Theme.SmartAir">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <!-- Registration Activity -->
        <activity
            android:name=".Registration"
            android:exported="false">

        </activity>
        <!-- Parent Activities -->
        <activity
            android:name=".parent.ParentDashboardWithChildrenActivity"
            android:exported="false" >
        </activity>
        <activity
            android:name=".parent.AddChildAccountActivity"
            android:exported="false" >
        </activity>
        <activity
            android:name=".parent.LinkAccountLayout"
            android:exported="false" >
        </activity>

        <!-- Child Activities -->
        <activity
            android:name=".child.ChildDashboardActivity"
            android:exported="false" >
        </activity>

        <!-- Forget Password Activities -->
        <activity
            android:name=".ForgetPasswordActivity"
            android:exported="false" >
        </activity>
        <!-- Provider Activity Activities -->
        <activity
            android:name=".provider.ProviderDashboardActivity"
            android:exported="false" />
        <!-- Child Dashboard Game Activities -->
        <activity
            android:name=".ChildDashboardGameActivity"
            android:exported="false" >
        </activity>
    </application>

</manifest>


